// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                            Int                            @id @default(autoincrement())
  name                          String
  email                         String                         @unique
  avatarUrl                     String?                        @map("avatar_url")
  passwordHash                  String?                        @map("password_hash")
  sessionVersion                Int                            @default(1) @map("session_version")
  timezone                      String?                        @db.VarChar(100)
  appRole                       String                         @default("user") @map("app_role") @db.VarChar(40)
  deactivatedAt                 DateTime?                      @map("deactivated_at")
  createdAt                     DateTime                       @default(now()) @map("created_at")
  updatedAt                     DateTime                       @updatedAt @map("updated_at")
  workspaces                    Workspace[]                    @relation("WorkspaceOwners")
  memberships                   WorkspaceMember[]
  authAccounts                  AuthAccount[]
  assignedTasks                 Task[]                         @relation("AssignedTasks")
  projects                      Project[]                      @relation("OwnedProjects")
  projectMemberships            ProjectMember[]
  labels                        Label[]                        @relation("OwnedLabels")
  createdTasks                  Task[]                         @relation("CreatedTasks")
  updatedTasks                  Task[]                         @relation("UpdatedTasks")
  createdTaskLinks              TaskLink[]                     @relation("TaskLinkCreators")
  uploadedTaskAttachments       TaskAttachment[]               @relation("TaskAttachmentUploaders")
  auditLogs                     AuditLog[]                     @relation("AuditActors")
  passwordResetTokens           PasswordResetToken[]
  taskNotificationSubscriptions TaskNotificationSubscription[]
  taskNotificationDeliveries    TaskNotificationDelivery[]

  @@index([appRole])
  @@index([deactivatedAt])
  @@map("users")
}

model PasswordResetToken {
  id               Int       @id @default(autoincrement())
  userId           Int       @map("user_id")
  tokenHash        String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt        DateTime  @map("expires_at")
  usedAt           DateTime? @map("used_at")
  requestIp        String?   @map("request_ip") @db.VarChar(120)
  requestUserAgent String?   @map("request_user_agent") @db.VarChar(500)
  createdAt        DateTime  @default(now()) @map("created_at")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
  @@map("password_reset_tokens")
}

model Workspace {
  id          Int               @id @default(autoincrement())
  ownerUserId Int?              @map("owner_user_id")
  name        String            @db.VarChar(160)
  description String?
  slug        String            @unique @db.VarChar(160)
  sortOrder   Int               @default(1) @map("sort_order")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  owner       User?             @relation("WorkspaceOwners", fields: [ownerUserId], references: [id], onDelete: SetNull)
  memberships WorkspaceMember[]
  projects    Project[]
  cycles      Cycle[]
  labels      Label[]
  repeatRules TaskRepeatRule[]
  auditLogs   AuditLog[]

  @@index([sortOrder])
  @@map("workspaces")
}

model WorkspaceMember {
  id          Int       @id @default(autoincrement())
  workspaceId Int       @map("workspace_id")
  userId      Int       @map("user_id")
  role        String    @db.VarChar(40)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

model ProjectMember {
  id        Int      @id @default(autoincrement())
  projectId Int      @map("project_id")
  userId    Int      @map("user_id")
  role      String   @db.VarChar(40)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId])
  @@map("project_members")
}

model AuthAccount {
  id                Int      @id @default(autoincrement())
  userId            Int      @map("user_id")
  provider          String   @db.VarChar(64)
  providerAccountId String   @map("provider_account_id") @db.VarChar(190)
  accountType       String   @map("account_type") @db.VarChar(40)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("auth_accounts")
}

model Project {
  id          Int              @id @default(autoincrement())
  workspaceId Int?             @map("workspace_id")
  ownerUserId Int?             @map("owner_user_id")
  name        String           @db.VarChar(200)
  description String?
  sortOrder   Int              @default(1) @map("sort_order")
  archivedAt  DateTime?        @map("archived_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  workspace   Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  owner       User?            @relation("OwnedProjects", fields: [ownerUserId], references: [id], onDelete: SetNull)
  members     ProjectMember[]
  tasks       Task[]
  cycles      Cycle[]
  repeatRules TaskRepeatRule[]

  @@index([workspaceId])
  @@index([archivedAt])
  @@index([sortOrder])
  @@map("projects")
}

model Task {
  id                        Int                            @id @default(autoincrement())
  projectId                 Int                            @map("project_id")
  createdByUserId           Int?                           @map("created_by_user_id")
  updatedByUserId           Int?                           @map("updated_by_user_id")
  assigneeUserId            Int?                           @map("assignee_user_id")
  cycleId                   Int?                           @map("cycle_id")
  parentTaskId              Int?                           @map("parent_task_id")
  repeatRuleId              Int?                           @map("repeat_rule_id")
  title                     String                         @db.VarChar(200)
  description               String?
  status                    String                         @db.VarChar(24)
  priority                  String                         @db.VarChar(24)
  startDate                 DateTime?                      @map("start_date") @db.Date
  dueDate                   DateTime?                      @map("due_date") @db.Date
  dueReminderTime           String?                        @map("due_reminder_time") @db.VarChar(5)
  repeatScheduledFor        DateTime?                      @map("repeat_scheduled_for") @db.Date
  repeatPeriodStart         DateTime?                      @map("repeat_period_start") @db.Date
  repeatPeriodEnd           DateTime?                      @map("repeat_period_end") @db.Date
  repeatSequence            Int?                           @map("repeat_sequence")
  repeatCarryCount          Int                            @default(0) @map("repeat_carry_count")
  sortOrder                 Int                            @default(1) @map("sort_order")
  version                   Int                            @default(1)
  createdAt                 DateTime                       @default(now()) @map("created_at")
  updatedAt                 DateTime                       @updatedAt @map("updated_at")
  project                   Project                        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator                   User?                          @relation("CreatedTasks", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updater                   User?                          @relation("UpdatedTasks", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  assignee                  User?                          @relation("AssignedTasks", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  cycle                     Cycle?                         @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  parentTask                Task?                          @relation("TaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull)
  childTasks                Task[]                         @relation("TaskHierarchy")
  repeatRule                TaskRepeatRule?                @relation("RepeatRuleTasks", fields: [repeatRuleId], references: [id], onDelete: SetNull)
  sourceRepeatRule          TaskRepeatRule?                @relation("RepeatRuleSourceTask")
  taskLabels                TaskLabel[]
  links                     TaskLink[]
  attachments               TaskAttachment[]
  notificationSubscriptions TaskNotificationSubscription[]
  notificationDeliveries    TaskNotificationDelivery[]

  @@unique([repeatRuleId, repeatScheduledFor])
  @@index([projectId])
  @@index([assigneeUserId])
  @@index([cycleId])
  @@index([parentTaskId])
  @@index([repeatRuleId])
  @@index([repeatScheduledFor])
  @@index([status])
  @@index([priority])
  @@index([startDate])
  @@index([dueDate])
  @@index([projectId, status, sortOrder])
  @@map("tasks")
}

model TaskLink {
  id              Int      @id @default(autoincrement())
  taskId          Int      @map("task_id")
  createdByUserId Int?     @map("created_by_user_id")
  title           String   @db.VarChar(200)
  url             String   @db.VarChar(2048)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  task            Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdBy       User?    @relation("TaskLinkCreators", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([createdByUserId])
  @@map("task_links")
}

model TaskAttachment {
  id               Int      @id @default(autoincrement())
  taskId           Int      @map("task_id")
  uploadedByUserId Int?     @map("uploaded_by_user_id")
  originalFileName String   @map("original_file_name") @db.VarChar(255)
  storageKey       String   @unique @map("storage_key") @db.VarChar(160)
  mimeType         String?  @map("mime_type") @db.VarChar(120)
  sizeBytes        Int      @map("size_bytes")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  task             Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy       User?    @relation("TaskAttachmentUploaders", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([uploadedByUserId])
  @@map("task_attachments")
}

model TaskNotificationSubscription {
  id        Int      @id @default(autoincrement())
  taskId    Int      @map("task_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
  @@map("task_notification_subscriptions")
}

model TaskNotificationDelivery {
  id          Int       @id @default(autoincrement())
  taskId      Int       @map("task_id")
  userId      Int       @map("user_id")
  kind        String    @db.VarChar(40)
  dedupeKey   String    @unique @map("dedupe_key") @db.VarChar(160)
  scheduledAt DateTime  @map("scheduled_at")
  status      String    @default("pending") @db.VarChar(24)
  attempts    Int       @default(0)
  claimedAt   DateTime? @map("claimed_at")
  sentAt      DateTime? @map("sent_at")
  failedAt    DateTime? @map("failed_at")
  lastError   String?   @map("last_error")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId, kind])
  @@index([userId])
  @@index([status, scheduledAt])
  @@index([taskId])
  @@map("task_notification_deliveries")
}

model TaskRepeatRule {
  id                 Int        @id @default(autoincrement())
  workspaceId        Int?       @map("workspace_id")
  projectId          Int        @map("project_id")
  sourceTaskId       Int?       @unique @map("source_task_id")
  isActive           Boolean    @default(true) @map("is_active")
  scheduleType       String     @map("schedule_type") @db.VarChar(40)
  interval           Int        @default(1)
  weekdays           Json?
  monthDay           Int?       @map("month_day")
  specificDates      Json?      @map("specific_dates")
  incompleteBehavior String     @map("incomplete_behavior") @db.VarChar(40)
  nextDueDate        DateTime?  @map("next_due_date") @db.Date
  lastSyncedAt       DateTime?  @map("last_synced_at")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")
  workspace          Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  project            Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceTask         Task?      @relation("RepeatRuleSourceTask", fields: [sourceTaskId], references: [id], onDelete: SetNull)
  tasks              Task[]     @relation("RepeatRuleTasks")

  @@index([workspaceId])
  @@index([projectId])
  @@index([isActive])
  @@index([nextDueDate])
  @@map("task_repeat_rules")
}

model Cycle {
  id          Int        @id @default(autoincrement())
  workspaceId Int?       @map("workspace_id")
  projectId   Int        @map("project_id")
  name        String     @db.VarChar(160)
  status      String     @default("planned") @db.VarChar(32)
  startDate   DateTime   @map("start_date") @db.Date
  endDate     DateTime   @map("end_date") @db.Date
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@index([workspaceId])
  @@index([projectId])
  @@index([startDate, endDate])
  @@map("cycles")
}

model Label {
  id          Int         @id @default(autoincrement())
  workspaceId Int?        @map("workspace_id")
  ownerUserId Int?        @map("owner_user_id")
  name        String      @db.VarChar(120)
  color       String      @default("#0f766e") @db.VarChar(7)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  workspace   Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  owner       User?       @relation("OwnedLabels", fields: [ownerUserId], references: [id], onDelete: SetNull)
  taskLabels  TaskLabel[]

  @@unique([name])
  @@index([workspaceId])
  @@map("labels")
}

model TaskLabel {
  id        Int      @id @default(autoincrement())
  labelId   Int      @map("label_id")
  taskId    Int      @map("task_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  label     Label    @relation(fields: [labelId], references: [id], onDelete: Cascade)
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([labelId, taskId])
  @@index([taskId])
  @@map("label_task")
}

model AuditLog {
  id          Int        @id @default(autoincrement())
  workspaceId Int?       @map("workspace_id")
  actorUserId Int?       @map("actor_user_id")
  entityType  String     @map("entity_type") @db.VarChar(48)
  entityId    String     @map("entity_id") @db.VarChar(120)
  action      String     @db.VarChar(80)
  summary     Json?
  createdAt   DateTime   @default(now()) @map("created_at")
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  actor       User?      @relation("AuditActors", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([action])
  @@map("audit_logs")
}
