FROM node:22-alpine

WORKDIR /app
ENV NEXT_TELEMETRY_DISABLED=1

COPY package.json package-lock.json ./
RUN npm ci

CMD ["sh", "-lc", "mkdir -p .next && find .next -mindepth 1 -maxdepth 1 -exec rm -rf {} + 2>/dev/null || true; npm run prisma:generate && npm run prisma:migrate && npm run dev -- --webpack --hostname 0.0.0.0 --port 3000"]
