APP_URL="http://localhost:3000"

POSTGRES_DB="taskewr"
POSTGRES_USER="taskewr"
POSTGRES_PASSWORD="taskewr"

DATABASE_URL="postgresql://taskewr:taskewr@localhost:5433/taskewr?schema=public"
SESSION_SECRET="taskewr-dev-session-secret"

SMTP_HOST="localhost" # SMTP server hostname; use localhost for Mailpit or your provider host, e.g. smtp.example.com.
SMTP_PORT=1025 # SMTP port; use 1025 for Mailpit, 587 for STARTTLS, or 465 for implicit SSL.
SMTP_SECURE=false # true only for implicit SSL on port 465; false for Mailpit and STARTTLS on port 587.
SMTP_REQUIRE_TLS=false # true when using STARTTLS, usually port 587; false for Mailpit and usually false for implicit SSL port 465.
SMTP_USER="" # SMTP username; leave empty for Mailpit, set your provider username/API user in production.
SMTP_PASSWORD="" # SMTP password/API key; leave empty for Mailpit, set with SMTP_USER for authenticated providers.
SMTP_FROM="Taskewr <no-reply@taskewr.local>" # Sender shown in emails; must be a sender/domain allowed by the SMTP provider.
SMTP_REPLY_TO="" # Optional reply-to address; leave empty to omit it or set a monitored support/no-reply address.

NOTIFICATION_WORKER_POLL_INTERVAL_MS=60000
NOTIFICATION_WORKER_BATCH_SIZE=50
NOTIFICATION_WORKER_MAX_ATTEMPTS=3
NOTIFICATION_WORKER_CLAIM_TIMEOUT_MS=300000

TASK_ATTACHMENT_STORAGE_DIR="uploads/task-attachments" # Local disk directory for uploaded task attachments; keep this gitignored and use persistent storage in deployed environments.
TASK_ATTACHMENT_MAX_BYTES=26214400 # Maximum task attachment size in bytes; default is 25 MB.
